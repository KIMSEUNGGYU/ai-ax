{
  "description": "FE 컨벤션 자동 적용 훅",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "remote|mutation|query|API|api|dto|DTO|schema|컴포넌트|페이지|구현|추가해|작성|연동|통합",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/fe-convention-prompt.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/post-edit-convention.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
